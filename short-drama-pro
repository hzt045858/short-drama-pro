#!/usr/bin/env python3
import os
import sys
import subprocess
from pathlib import Path

ROOT = Path(__file__).resolve().parent
SCRIPTS = ROOT / 'scripts'

COMMANDS = {
    'start': 'start.py',
    'plan': 'plan.py',
    'characters': 'characters.py',
    'catalog': 'catalog.py',
    'episode': 'episode.py',
    'check': 'check.py',
    'export': 'export.py',
    'help': None,
    '--help': None,
    '-h': None,
}

HELP = '''专业短剧技能入口

用法:
  ./short-drama-pro <command> [args]

命令:
  start       创建项目
  plan        生成创作方案
  characters  生成角色档案
  catalog     生成剧集目录
  episode     生成单集剧本
  check       自检项目/剧本
  export      导出项目
  help        显示帮助
'''


def main():
    argv = sys.argv[1:]
    if not argv or argv[0] in ('help', '--help', '-h'):
        print(HELP)
        return 0

    cmd = argv[0]
    target = COMMANDS.get(cmd)
    if not target:
        print(f'未知命令: {cmd}', file=sys.stderr)
        print(HELP)
        return 2

    script = SCRIPTS / target
    if not script.exists():
        print(f'缺少脚本: {script}', file=sys.stderr)
        return 2

    env = os.environ.copy()
    forwarded = list(argv[1:])
    if '--project-dir' not in forwarded and cmd != 'start':
        candidates = sorted(ROOT.glob('short-drama-project-*'), key=lambda p: p.stat().st_mtime, reverse=True)
        if candidates:
            forwarded.extend(['--project-dir', str(candidates[0])])
    result = subprocess.run([sys.executable, str(script), *forwarded], cwd=str(ROOT), env=env)
    return result.returncode


if __name__ == '__main__':
    raise SystemExit(main())
